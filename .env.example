TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Freelancer account credentials — used to log in via headless Chrome
# so the API returns full client data (name, country, verification, completion rate)
FREELANCER_EMAIL=
FREELANCER_PASSWORD=

# Set to "false" to show the browser window during login (useful for debugging)
# On VPS leave this unset (defaults to headless=true)
# HEADLESS=false

# One or more Freelancer search URLs to monitor, separated by | (pipe).
# Use pipe NOT comma — the URLs contain commas in the skill IDs.
# Example (single URL):
#   FREELANCER_SEARCH_URLS=https://www.freelancer.com/search/projects?projectSkills=3,9,13&projectLanguages=en,de
# Example (multiple URLs):
#   FREELANCER_SEARCH_URLS=https://www.freelancer.com/search/projects?projectSkills=3,9&projectLanguages=en | https://www.freelancer.com/search/projects?projectSkills=13,15&projectLanguages=de
FREELANCER_SEARCH_URLS=

# Fast-layer rules
REQUIRED_SKILLS=
MIN_BUDGET_USD=0
SCAM_KEYWORDS=telegram,whatsapp,contact me,verification fee,crypto,kindly,gift card

# Polling
POLL_INTERVAL_MS=5000

# Optional AI enrichment (runs after notifying)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
