# Set TELEGRAM_ENABLED=false to run UI-only (no Telegram messages).
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Freelancer account credentials — used to log in via headless Chrome
# so the API returns full client data (name, country, verification, completion rate)
FREELANCER_EMAIL=
FREELANCER_PASSWORD=

# Login browser: visible Chrome by default so you can solve CAPTCHA manually.
# Set LOGIN_HEADLESS=true only on headless servers (e.g. VPS with Xvfb).
# LOGIN_HEADLESS=false

# Profile scraping after login: set HEADLESS=false to keep browser visible, true for background.
# HEADLESS=true

# If CAPTCHA is shown during login, the bot waits for you to solve it in the browser window.
# Default when login browser is visible: 30 minutes. Set to 0 for indefinite wait.
# CAPTCHA_WAIT_MS=1800000

# One or more Freelancer search URLs to monitor, separated by | (pipe).
# Use pipe NOT comma — the URLs contain commas in the skill IDs.
# Example (single URL):
#   FREELANCER_SEARCH_URLS=https://www.freelancer.com/search/projects?projectSkills=3,9,13&projectLanguages=en,de
# Example (multiple URLs):
#   FREELANCER_SEARCH_URLS=https://www.freelancer.com/search/projects?projectSkills=3,9&projectLanguages=en | https://www.freelancer.com/search/projects?projectSkills=13,15&projectLanguages=de
FREELANCER_SEARCH_URLS=

# Fast-layer rules
REQUIRED_SKILLS=
MIN_BUDGET_USD=0
SCAM_KEYWORDS=telegram,whatsapp,contact me,verification fee,crypto,kindly,gift card

# Polling
POLL_INTERVAL_MS=5000

# Dashboard (local UI)
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3030
DASHBOARD_MAX_ITEMS=50
# SQLite database file for per-user settings (OpenAI key + bid styles)
DASHBOARD_SQLITE_PATH=data/dashboard.sqlite
# Used to sign the login cookie + encrypt OpenAI keys (change this!)
DASHBOARD_AUTH_SECRET=change-me-long-random

# Optional AI enrichment (legacy direct OpenAI — bids use OpenRouter pool below)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# OpenRouter — shared model for bid generation (admin manages keys in dashboard)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Slack — each user connects their own Slack account (OAuth).
# Messages post as that user in #Good Job and can be deleted normally.
#
# Slack app setup (use your existing app):
# 1) OAuth & Permissions → Redirect URL:
#    http://localhost:3030/api/slack/oauth/callback
#    (add your production URL too if deployed)
# 2) User Token Scopes: chat:write
# 3) Basic Information → copy Client ID + Client Secret
# 4) #Good Job channel ID (C...)
SLACK_ENABLED=true
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_CHANNEL_ID=
# Legacy (optional, not used for sending anymore)
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
